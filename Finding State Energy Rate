function rate = stateenergyfinder(stateName)
% Load the CSV exported from Google Sheets
T = readtable("Energy Rates US - Sheet1.csv","TextType","string");

states = T{:,1};

energy_rate = T{:,2};

% Combine into a 50x2 cell matrix (text + numbers)
M = [cellstr(states) num2cell(energy_rate)];

%looks for when the state inputted matches one of the states in the data
idx = states == stateName;

%gives the according rate in that row
rate = energy_rate(idx)

end
