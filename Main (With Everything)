% Assumed panel power rating in watts
panel_rating = 400;

% Calculate the cost of one panel based on the selected state
cost_per_panel = Panel_cost_calc(state);

% Calculate the number of panels that can be installed
max_panels = calculateMaxPanels(roof_size, panel_area, budget, cost_per_panel);

%% Energy Production Function
% This function estimates annual energy production from the solar system
function annual_production = calculateEnergyProduction(panels, irradiance, panel_wattage, system_efficiency)

    % panels (#)
    % irradiance (W/m^2)
    % panel_wattage (W)
    % system_efficiency (%)

    % Calculate daily energy production in Wh/day
    daily_production = panels * panel_wattage * irradiance * system_efficiency;

    % Convert daily production to annual production in kWh/year
    annual_production = daily_production * 365 / 1000;
end

%% Energy Production Calculation
% Average efficiency of 400 W panels
system_efficiency = .8;
panel_efficiency = .2;

% Calculate annual energy production
annual_production = calculateEnergyProduction(max_panels, irradiance, panel_rating, system_efficiency);
annual_Savings = annual_production*.19;
Total_spent = max_panels*cost_per_panel;
PBP = Total_spent/annual_Savings;

%% Additional User Inputs for Financial Calculations

% Ask the user for their annual electricity consumption
annual_usage = input('Please enter your annual electricity usage (kWh): ');

while annual_usage <= 0
    annual_usage = input('Invalid value. Enter a positive annual electricity usage (kWh): ');
end

% Electricity price ($ per kWh)
electricity_price = 0.19;

% Export compensation for excess electricity
export_rate = 0.08;

% Solar system lifetime (years)
system_lifetime = 25;

%% Optimization
% Select the system that provides the best balance of
% lifetime savings and payback period.

for p = 1:max_panels

    % Energy production
    production(p) = calculateEnergyProduction(p, irradiance, panel_rating, system_efficiency);

    % Energy usage
    energy_used = min(production(p), annual_usage);
    energy_exported = max(0, production(p) - annual_usage);

    % Annual savings
    savings(p) = energy_used * electricity_price + energy_exported * export_rate;

    % System cost
    system_cost(p) = p * cost_per_panel;

    % Payback
    payback(p) = system_cost(p) / savings(p);

    % Lifetime savings
    lifetime_savings(p) = savings(p) * system_lifetime - system_cost(p);

end

%% Optimal System Selection
% Choose the system that maximizes the ratio of
% lifetime savings to payback period

score = lifetime_savings ./ payback;

[~, optimal_panels] = max(score);

optimal_cost = system_cost(optimal_panels);
optimal_savings = savings(optimal_panels);
optimal_payback = payback(optimal_panels);
optimal_lifetime = lifetime_savings(optimal_panels);
optimal_production = production(optimal_panels);

