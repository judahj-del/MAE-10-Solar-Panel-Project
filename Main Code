%% Solar Energy Optimization Tool
% This script:
% 1. Welcomes the user and explains the program
% 2. Collects and validates location inputs
% 3. Determines panel cost based on state
% 4. Pulls solar resource data from the API
% 5. Calculates the maximum number of panels allowed by roof size and budget
% 6. Estimates annual energy production


%% Welcome Message
% Display a multiline introduction to the user
fprintf(['Welcome to our Solar Energy Optimization Tool.\n' ...
    'Using real world solar data and engineering calculations,\n' ...
    'this program evaluates energy production and recommends the\n' ...
    'most efficient solar panel configuration based on your\n' ...
    'exact location, budget, and available space.\n\n']);


%% User Input: Latitude
% Read latitude as a string first so it can be validated
Lat_str = input('Please input your Lattitude (Decimal Degrees): ', 's');
Lat = str2double(Lat_str);


% Keep asking until the input is a valid number
while isnan(Lat) || isempty(Lat)
    Lat_str = input(sprintf('%s is not a valid number. Please input a numeric Lattitude: ', Lat_str), 's');
    Lat = str2double(Lat_str);
end


%% User Input: Longitude
% Read longitude as a string first so it can be validated
Lon_str = input('Please input your Longitude (Decimal Degrees): ', 's');
Lon = str2double(Lon_str);


% Keep asking until the input is a valid number
while isnan(Lon) || isempty(Lon)
    Lon_str = input(sprintf('%s is not a valid number. Please input a numeric Longitude: ', Lon_str), 's');
    Lon = str2double(Lon_str);
end


%% User Input: State
% Ask the user for their state
state = input('Please input your State: ', 's');


% Confirm the location information entered by the user
fprintf('\nLocation set: Lat %.2f, Lon %.2f, State: %s\n', Lat, Lon, state);


%% Panel Cost Function
% This function calculates the cost per panel in each state.
% For this project, each panel is assumed to be rated at 400 W.
function cost_per_panel = Panel_cost_calc(state)


%% API Setup and Solar Data Request
% API key for solar resource data
apiKey = "eUJcZnj1dgevasrCDhVXKBTzandkwZgSdsag0RTm";

% Build the API request URL using the user's latitude and longitude
url = sprintf(['https://developer.nlr.gov/api/solar/solar_resource/v1.json?', ...
               'api_key=%s&lat=%f&lon=%f'], ...
               apiKey, Lat, Lon);


% Retrieve solar data from the API
api_call = webread(url);


%% Calculating Number of Panels
% Ask the user for roof size in square meters
roof_size = input('Please provide the area of your roof (m^2): ');


% Validate roof size
while roof_size <= 2
    roof_size = input('You have entered too small of a roof size, please enter a new area: ');
end

% Ask the user for project budget
budget = input('Please enter your budget for this project: ');

% Validate budget
while budget < 0
    budget = input('You have entered an invalid value for budget, must be a positive number. Please enter a new value: ');
end

%% Maximum Panel Calculation Function
% This function determines the maximum number of panels based on:
% 1. Available roof area
% 2. Available budget
function max_panels = calculateMaxPanels(roof_size, panel_area, budget, cost_per_panel)

    % Maximum number of panels allowed by budget
    budget_max = floor(budget / cost_per_panel);

    % Maximum number of panels allowed by roof size
    max_panels = floor(roof_size / panel_area);

    % Use the smaller of the two limits
    if max_panels > budget_max
        max_panels = budget_max;
    end
end

%% Solar Panel Assumptions and Inputs
% Annual average direct normal irradiance from API data
irradiance = api_call.outputs.avg_dni.annual;

% Assumed panel area in square meters
panel_area = 2;

% Assumed panel power rating in watts
panel_rating = 400;

% Calculate the cost of one panel based on the selected state
cost_per_panel = Panel_cost_calc(state);

% Calculate the number of panels that can be installed
num_panels = calculateMaxPanels(roof_size, panel_area, budget, cost_per_panel);

%% Energy Production Function
% This function estimates annual energy production from the solar system
function annual_production = calculateEnergyProduction(panels, irradiance, panel_wattage, system_efficiency)

    % panels (#)
    % irradiance (W/m^2)
    % panel_wattage (W)
    % system_efficiency (%)

    % Calculate daily energy production in Wh/day
    daily_production = panels * panel_wattage * irradiance * system_efficiency;

    % Convert daily production to annual production in kWh/year
    annual_production = daily_production * 365 / 1000;
end

%% Energy Production Calculation
% Average efficiency of 400 W panels
system_efficiency = .2;

% Calculate annual energy production
annual_production = calculateEnergyProduction(num_panels, irradiance, panel_rating, system_efficiency);
annual_Savings = annual_production*.19;
Total_spent = num_panels*cost_per_panel;
%% Cost Breakdown of System

fprintf("\n--------Savings Report---------\n\nTotal Spent: %.2f\nAnnual Energy Production: %.2f Kilowatts.\nNumber of Panels: %d\nAnnual Savings: $%.2f\n",Total_spent, annual_production,num_panels, annual_Savings)
